  "keyFeatures": [
    "Checkout payment flow with WebView integration",
    "Pay With PayMaya for single payments and wallet linking",
    "Vault card tokenization for secure payment tokens",
    "Support for sandbox and production environments",
    "Automatic payment status checking",
    "Comprehensive error handling and result callbacks"
  ],
  "publicApiSurface": [
    "PayMayaCheckout.newBuilder()",
    "PayMayaCheckout.startCheckoutActivityForResult()",
    "PayMayaCheckout.onActivityResult()",
    "PayMayaCheckout.checkPaymentStatus()",
    "PayWithPayMaya.newBuilder()",
    "PayWithPayMaya.startSinglePaymentActivityForResult()",
    "PayWithPayMaya.startCreateWalletLinkActivityForResult()",
    "PayWithPayMaya.onActivityResult()",
    "PayWithPayMaya.checkPaymentStatus()",
    "PayMayaVault.newBuilder()",
    "PayMayaVault.startTokenizeCardActivityForResult()",
    "PayMayaVault.onActivityResult()",
    "CheckoutRequest",
    "SinglePaymentRequest",
    "CreateWalletLinkRequest",
    "PayMayaEnvironment.SANDBOX",
    "PayMayaEnvironment.PRODUCTION",
    "LogLevel",
    "PaymentStatus"
  ]
